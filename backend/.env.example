# Database URL - SQLite for development, PostgreSQL for production
# SQLite:   sqlite:///./support_tickets.db
# Postgres: postgresql://user:password@localhost:5432/support_tickets
DATABASE_URL=sqlite:///./support_tickets.db

# JWT Configuration
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173

# Optional: OpenAI API key for AI-powered reply suggestions
# Leave empty to use built-in template-based suggestions
OPENAI_API_KEY=
