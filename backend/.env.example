# Database URL - SQLite for development, PostgreSQL for production
# SQLite:   sqlite:///./support_tickets.db
# Postgres: postgresql://user:password@localhost:5432/support_tickets
DATABASE_URL=sqlite:///./support_tickets.db

# JWT Configuration
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173

# LLM for AI reply suggestions — Groq is FREE (no credit card needed)
# Get your free key at: https://console.groq.com
# Uses Llama 3.3 70B model — fast and free
GROQ_API_KEY=

# Optional: OpenAI fallback (only used if GROQ_API_KEY is not set)
OPENAI_API_KEY=

# Optional: Remote Qdrant URL (Phase 2)
# Leave empty to use in-process :memory: Qdrant (resets on restart)
# Example: http://localhost:6333
QDRANT_URL=

# Optional: Path to fine-tuned embedding model checkpoint (Phase 4)
# Leave empty to use the default all-MiniLM-L6-v2
# Example: ./models/ticket-minilm-finetuned
EMBEDDING_MODEL_PATH=

# HuggingFace Hub model ID for DistilBERT priority classifier (Phase 5)
# Set this to load the 94%-accuracy classifier on cloud deployments (Render, etc.)
# where the local ./models/priority-distilbert/ folder doesn't exist.
# Get the model at: https://huggingface.co/somtomxr/ticket-priority-distilbert
HF_MODEL_ID=somtomxr/ticket-priority-distilbert
